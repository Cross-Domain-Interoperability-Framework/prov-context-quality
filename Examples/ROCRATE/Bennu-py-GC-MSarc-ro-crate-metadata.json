    {
      "@id": "#PyGCMS_Protocol",
      "@type": ["File", "SoftwareSourceCode", "ComputationalWorkflow", "LabProtocol"],
      "name": "Py-GC-MS/MS analysis protocol for OSIRIS-REx Bennu sample",
      "description": "Flash pyrolysis coupled to gas chromatography-tandem mass spectrometry with simultaneous full scan (m/z 50–500) and timed SRM/MRM acquisition targeting 38 organic compounds. Method identifier: Mojarro_88min_MRM_4_IOM+FullScan_10_1_Split_py.",
      "intendedUse": "Characterization of complex organic mixtures in bulk solid extraterrestrial samples by direct microanalysis without chemical pretreatment.",
      "measurementMethod": "Pyrolysis-GC-MS/MS",
      "labEquipment": [
        {"@id": "#PyrolysisOven"},
        {"@id": "#GasChromatograph"},
        {"@id": "#TSQ_MassSpectrometer"}
      ],
      "hasPart": [
        {"@id": "#SamplePrep_Protocol"},
        {"@id": "#Pyrolysis_Protocol"},
        {"@id": "#GCSeparation_Protocol"},
        {"@id": "#MSDetection_Protocol"}
      ],
      "input": [
        {"@id": "#param_sampleMass"},
        {"@id": "#param_pyrolysisTemp"},
        {"@id": "#param_pyrolysisRate"}
      ],
      "output": [
        {"@id": "#param_outputFormat"}
      ]
    },


    {
      "@id": "#SamplePrep_Protocol",
      "@type": ["SoftwareSourceCode", "LabProtocol"],
      "name": "Sample preparation protocol",
      "description": "Load and weigh bulk solid sample inside quartz tubes, place into pyrolysis oven interfaced with GC-MS.",
      "labEquipment": [
        {"@id": "#QuartzTubes"},
        {"@id": "#PyrolysisOven"}
      ],
      "input": [{"@id": "#param_sampleMass"}],
      "output": [{"@id": "#param_preparedSampleForm"}]
    },
    {
      "@id": "#Pyrolysis_Protocol",
      "@type": ["SoftwareSourceCode", "LabProtocol"],
      "name": "Flash pyrolysis protocol",
      "description": "Flash heat prepared sample to target temperature at controlled ramp rate. Thermally extracted volatiles carried in helium through heated transfer line (300°C) to GC inlet.",
      "labEquipment": [{"@id": "#PyrolysisOven"}],
      "input": [
        {"@id": "#param_pyrolysisTemp"},
        {"@id": "#param_pyrolysisRate"},
        {"@id": "#param_transferLineTemp"}
      ]
    },
    {
      "@id": "#GCSeparation_Protocol",
      "@type": ["SoftwareSourceCode", "LabProtocol"],
      "name": "Gas chromatographic separation protocol",
      "description": "Separate pyrolysis products on nonpolar fused silica capillary column with temperature program from initial hold through ramp to final hold.",
      "labEquipment": [{"@id": "#GasChromatograph"}],
      "input": [
        {"@id": "#param_columnType"},
        {"@id": "#param_carrierGasFlow"},
        {"@id": "#param_splitRatio"},
        {"@id": "#param_inletTemp"},
        {"@id": "#param_ovenProgram"}
      ]
    },
    {
      "@id": "#MSDetection_Protocol",
      "@type": ["SoftwareSourceCode", "LabProtocol"],
      "name": "Dual-mode MS detection protocol (full scan + timed SRM/MRM)",
      "description": "Simultaneous full scan (m/z 50–500, EI positive) and timed SRM/MRM acquisition monitoring 38 target compounds via 2–3 diagnostic precursor→product ion transitions each.",
      "labEquipment": [{"@id": "#TSQ_MassSpectrometer"}],
      "input": [
        {"@id": "#param_scanRange"},
        {"@id": "#param_ionizationMode"},
        {"@id": "#param_mrmCompoundCount"}
      ]
    },


